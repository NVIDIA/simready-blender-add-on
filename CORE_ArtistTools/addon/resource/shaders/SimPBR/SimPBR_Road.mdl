export annotation dither_masked_off();
export annotation world_space_normal();

export material SimPBR_Road(
	float2 TileOrigin
	[[
		anno::display_name("TileOrigin"),
		anno::in_group("Base", "Common")
	]],
	float2 TileSize
	[[
		anno::display_name("TileSize"),
		anno::in_group("Base", "Common")
	]],
	float WorldSpaceUVMult = 5000.0
	[[
		anno::display_name("WorldSpaceUVMult"),
		anno::in_group("Base", "Common")
	]],
	float Set1Tile = 4.0
	[[
		anno::display_name("Set1Tile"),
		anno::in_group("Base", "Set1")
	]],
	uniform texture_2d Set1SuperNormal = texture_2d("./drivable_surfaces/general/road/road_adv/set1supernormal.TGA",::tex::gamma_linear)
	[[
		anno::display_name("Set1SuperNormal"),
		sampler_color(),
		anno::in_group("Normals", "Set1"),
		anno::usage("normal")
	]],
	float Set2Tile = 8.0
	[[
		anno::display_name("Set2Tile"),
		anno::in_group("Base", "Set2")
	]],
	uniform texture_2d Set2SuperNormal = texture_2d("./drivable_surfaces/general/road/road_adv/set1supernormal.TGA",::tex::gamma_linear)
	[[
		sampler_color(),
		anno::display_name("Set2SuperNormal"),
		anno::in_group("Normals", "Set2"),
		anno::usage("normal")
	]],
	float Set1Set2BlendNoiseTile = 1.0
	[[
		anno::display_name("Set1Set2BlendNoiseTile"),
		anno::in_group("Base", "Common")
	]],
	uniform texture_2d Set1Set2BlendNoise = texture_2d("./drivable_surfaces/general/road/road_adv/t_noise_d.png",::tex::gamma_linear)
	[[
		sampler_color(),
		anno::display_name("Set1Set2BlendNoise"),
		anno::in_group("Base", "Common"),
		anno::usage("normal_blend_scale")
	]],
	float NormalConvert = 1.0
	[[
		anno::display_name("NormalConvert"),
		anno::in_group("Normals", "Common")
	]],
	float NormalAmount = 0.2
	[[
		anno::display_name("NormalAmount"),
		anno::in_group("Normals", "Common")
	]],
	float Stain0_NormalAmount = 0.2
	[[
		anno::display_name("Stain0_NormalAmount"),
		anno::in_group("Normals", "Stain 0")
	]],
	float Stain0_NoiseTile = 0.75
	[[
		anno::display_name("Stain0_NoiseTile"),
		anno::in_group("Regions", "Stain 0")
	]],
	uniform texture_2d Stain_Noise = texture_2d("./drivable_surfaces/general/road/road_adv/t_noise_d.png",::tex::gamma_srgb)
	[[
		sampler_color(),
		anno::display_name("Stain_Noise"),
		anno::in_group("Regions"),
		anno::usage("base_color")
	]],
	float Stain0_ParamA = 0.0
	[[
		anno::display_name("Stain0_ParamA"),
		anno::in_group("Regions", "Stain 0")
	]],
	float Stain0_ParamB = 0.0
	[[
		anno::display_name("Stain0_ParamB"),
		anno::in_group("Regions", "Stain 0")
	]],
	float Stain0_ParamC = 0.0
	[[
		anno::display_name("Stain0_ParamC"),
		anno::in_group("Regions", "Stain 0")
	]],
	float Stain0_Width = 2.0
	[[
		anno::display_name("Stain0_Width"),
		anno::in_group("Regions", "Stain 0")
	]],
	int VertexColorCoordinateIndex = 0
	[[
		anno::display_name("VertexColorCoordinateIndex"),
		anno::in_group("Base", "Common")
	]],
	uniform texture_2d UV_VertexColor = texture_2d("./drivable_surfaces/general/road/road_adv/t_noise_d.png",::tex::gamma_srgb)
	[[
		sampler_color(),
		anno::display_name("UV_VertexColor"),
		anno::in_group("Base", "Common"),
		anno::usage("base_color")
	]],
	float UV_UseVertexColorFromTexture = 1.0
	[[
		anno::display_name("UV_UseVertexColorFromTexture"),
		anno::in_group("Base", "Common")
	]],
	float Stain0_NoiseBlend = 2.0
	[[
		anno::display_name("Stain0_NoiseBlend"),
		anno::in_group("Regions", "Stain 0")
	]],
	float Stain0_Blend = 1.0
	[[
		anno::display_name("Stain0_Blend"),
		anno::in_group("Regions", "Stain 0")
	]],
	float Stain1_NormalAmount = 0.2
	[[
		anno::display_name("Stain1_NormalAmount"),
		anno::in_group("Normals", "Stain 1")
	]],
	float Stain1_NoiseTile = 0.15
	[[
		anno::display_name("Stain1_NoiseTile"),
		anno::in_group("Regions", "Stain 1")
	]],
	float Stain1_ParamA = 0.0
	[[
		anno::display_name("Stain1_ParamA"),
		anno::in_group("Regions", "Stain 1")
	]],
	float Stain1_ParamB = 0.0
	[[
		anno::display_name("Stain1_ParamB"),
		anno::in_group("Regions", "Stain 1")
	]],

	float Stain1_ParamC = 0.0
	[[
		anno::display_name("Stain1_ParamC"),
		anno::in_group("Regions", "Stain 1")
	]],
	float Stain1_Width = 1.0
	[[
		anno::display_name("Stain1_Width"),
		anno::in_group("Regions", "Stain 1")
	]],
	float Stain1_NoiseBlend = 2.0
	[[
		anno::display_name("Stain1_NoiseBlend"),
		anno::in_group("Regions", "Stain 1")
	]],
	float Stain1_Blend = 0.333
	[[
		anno::display_name("Stain1_Blend"),
		anno::in_group("Regions", "Stain 1")
	]],
	float Stain2_NormalAmount = 0.2
	[[
		anno::display_name("Stain2_NormalAmount"),
		anno::in_group("Normals", "Stain 2")
	]],
	float Stain2_NoiseTile = 0.75
	[[
		anno::display_name("Stain2_NoiseTile"),
		anno::in_group("Regions", "Stain 2")
	]],
	float Stain2_ParamA = 0.0
	[[
		anno::display_name("Stain2_ParamA"),
		anno::in_group("Regions", "Stain 2")
	]],
	float Stain2_ParamB = 0.0
	[[
		anno::display_name("Stain2_ParamB"),
		anno::in_group("Regions", "Stain 2")
	]],
	float Stain2_ParamC = 0.0
	[[
		anno::display_name("Stain2_ParamC"),
		anno::in_group("Regions", "Stain 2")
	]],
	float Stain2_Width = 0.5
	[[
		anno::display_name("Stain2_Width"),
		anno::in_group("Regions", "Stain 2")
	]],
	float Stain2_NoiseBlend = 0.0
	[[
		anno::display_name("Stain2_NoiseBlend"),
		anno::in_group("Regions", "Stain 2")
	]],
	float Stain2_Blend = 1.0
	[[
		anno::display_name("Stain2_Blend"),
		anno::in_group("Regions", "Stain 2")
	]],
	float Puddle_NormalAmount = 0.0
	[[
		anno::display_name("Puddle_NormalAmount"),
		anno::in_group("Normals", "Puddle")
	]],
	float Puddle_NoiseTile = 0.5
	[[
		anno::display_name("Puddle_NoiseTile"),
		anno::in_group("Regions", "Puddle")
	]],
	uniform texture_2d Puddle_Noise = texture_2d("./drivable_surfaces/general/road/road_adv/t_noise01.png",::tex::gamma_srgb)
	[[
		sampler_color(),
		anno::display_name("Puddle_Noise"),
		anno::in_group("Regions", "Puddle"),
		anno::usage("base_color")
	]],
	float Puddle_NoiseBlend = 0.2
	[[
		anno::display_name("Puddle_NoiseBlend"),
		anno::in_group("Regions", "Puddle")
	]],
	uniform texture_2d Set1SuperAlbedo = texture_2d("./drivable_surfaces/general/road/road_adv/set1superalbedo.TGA",::tex::gamma_srgb)
	[[
		sampler_color(),
		anno::display_name("Set1SuperAlbedo"),
		anno::in_group("Albedos", "Set1"),
		anno::usage("base_color")
	]],
	uniform texture_2d Set2SuperAlbedo = texture_2d("./drivable_surfaces/general/road/road_adv/set1superalbedo.TGA",::tex::gamma_srgb)
	[[
		sampler_color(),
		anno::display_name("Set2SuperAlbedo"),
		anno::in_group("Albedos", "Set2"),
		anno::usage("base_color")
	]],
	float4 AlbedoMult = float4(1.75,1.75,1.75,0.0)
	[[
		anno::display_name("AlbedoMult"),
		anno::in_group("Albedos", "Common")
	]],
	float4 Stain0_AlbedoMult = float4(1.0,1.0,1.0,1.0)
	[[
		anno::display_name("Stain0_AlbedoMult"),
		anno::in_group("Albedos", "Stain 0")
	]],
	float4 Stain1_AlbedoMult = float4(1.0,1.0,1.0,1.0)
	[[
		anno::display_name("Stain1_AlbedoMult"),
		anno::in_group("Albedos", "Stain 1")
	]],
	float4 Stain2_AlbedoMult = float4(1.0,1.0,1.0,1.0)
	[[
		anno::display_name("Stain2_AlbedoMult"),
		anno::in_group("Albedos", "Stain 2")
	]],
	float Puddle_AlbedoMult = 1.0
	[[
		anno::display_name("Puddle_AlbedoMult"),
		anno::in_group("Albedos", "Puddle")
	]],
	float SpecularPow_Order1 = 0.3
	[[
		anno::display_name("SpecularPow_Order1"),
		anno::in_group("Speculars", "Common")
	]],
	float SpecularMult_Order2 = 0.2
	[[
		anno::display_name("SpecularMult_Order2"),
		anno::in_group("Speculars", "Common")
	]],
	float Stain0_SpecularPow_Order1 = 0.3
	[[
		anno::display_name("Stain0_SpecularPow_Order1"),
		anno::in_group("Speculars", "Stain 0")
	]],
	float Stain0_SpecularMult_Order2 = 0.2
	[[
		anno::display_name("Stain0_SpecularMult_Order2"),
		anno::in_group("Speculars", "Stain 0")
	]],
	float Stain1_SpecularPow_Order1 = 0.3
	[[
		anno::display_name("Stain1_SpecularPow_Order1"),
		anno::in_group("Speculars", "Stain 1")
	]],
	float Stain1_SpecularMult_Order2 = 0.6
	[[
		anno::display_name("Stain1_SpecularMult_Order2"),
		anno::in_group("Speculars", "Stain 1")
	]],
	float Stain2_SpecularPow_Order1 = 0.3
	[[
		anno::display_name("Stain2_SpecularPow_Order1"),
		anno::in_group("Speculars", "Stain 2")
	]],
	float Stain2_SpecularMult_Order2 = 0.5
	[[
		anno::display_name("Stain2_SpecularMult_Order2"),
		anno::in_group("Speculars", "Stain 2")
	]],
	float Puddle_SpecularPow_Order1 = 2.0
	[[
		anno::display_name("Puddle_SpecularPow_Order1"),
		anno::in_group("Speculars", "Puddle")
	]],
	float Puddle_SpecularMult_Order2 = 0.32
	[[
		anno::display_name("Puddle_SpecularMult_Order2"),
		anno::in_group("Speculars", "Puddle")
	]],
	float RoughnessPow_Order1 = 0.5
	[[
		anno::display_name("RoughnessPow_Order1"),
		anno::in_group("Roughnesses", "Common")
	]],
	float RoughnessMult_Order2 = 1.0
	[[
		anno::display_name("RoughnessMult_Order2"),
		anno::in_group("Roughnesses", "Common")
	]],
	float RoughnessOffset_Order3 = 0.0
	[[
		anno::display_name("RoughnessOffset_Order3"),
		anno::in_group("Roughnesses", "Common")
	]],
	float Stain0_RoughnessPow_Order1 = 0.5
	[[
		anno::display_name("Stain0_RoughnessPow_Order1"),
		anno::in_group("Roughnesses", "Stain 0")
	]],
	float Stain0_RoughnessMult_Order2 = 0.5
	[[
		anno::display_name("Stain0_RoughnessMult_Order2"),
		anno::in_group("Roughnesses", "Stain 0")
	]],
	float Stain0_RoughnessOffset_Order3 = 0.0
	[[
		anno::display_name("Stain0_RoughnessOffset_Order3"),
		anno::in_group("Roughnesses", "Stain 0")
	]],
	float Stain1_RoughnessPow_Order1 = 0.5
	[[
		anno::display_name("Stain1_RoughnessPow_Order1"),
		anno::in_group("Roughnesses", "Stain 1")
	]],
	float Stain1_RoughnessMult_Order2 = 0.5
	[[
		anno::display_name("Stain1_RoughnessMult_Order2"),
		anno::in_group("Roughnesses", "Stain 1")
	]],
	float Stain1_RoughnessOffset_Order3 = 0.0
	[[
		anno::display_name("Stain1_RoughnessOffset_Order3"),
		anno::in_group("Roughnesses", "Stain 1")
	]],
	float Stain2_RoughnessPow_Order1 = 0.5
	[[
		anno::display_name("Stain2_RoughnessPow_Order1"),
		anno::in_group("Roughnesses", "Stain 2")
	]],
	float Stain2_RoughnessMult_Order2 = 0.5
	[[
		anno::display_name("Stain2_RoughnessMult_Order2"),
		anno::in_group("Roughnesses", "Stain 2")
	]],
	float Stain2_RoughnessOffset_Order3 = 0.0
	[[
		anno::display_name("Stain2_RoughnessOffset_Order3"),
		anno::in_group("Roughnesses", "Stain 2")
	]],
	float Puddle_RoughnessPow_Order1 = 1.0
	[[
		anno::display_name("Puddle_RoughnessPow_Order1"),
		anno::in_group("Roughnesses", "Puddle")
	]],
	float Puddle_RoughnessMult_Order2 = 1.0
	[[
		anno::display_name("Puddle_RoughnessMult_Order2"),
		anno::in_group("Roughnesses", "Puddle")
	]],
	float Puddle_RoughnessOffset_Order3 = 0.0
	[[
		anno::unused(),
		anno::display_name("Puddle_RoughnessOffset_Order3"),
		anno::in_group("Roughnesses", "Puddle")
	]],


	// -------------------- Wetness ----------------------
    uniform bool enable_wetness = false
    [[
        anno::description("Enable wetness controls on the object"),
        anno::display_name("Enable wetness"),
        anno::in_group("Wetness parameters")
    ]],
    float wetness = 0.0f
    [[
        anno::description("Controls the wetness of the object"),
        anno::display_name("Wetness strength"),
        anno::in_group("Wetness parameters"),
        anno::hard_range(0.0, 1.0)
    ]],
    float porosity = 0.5f
    [[
        anno::description("Controls the porosity of the object"),
        anno::display_name("Porosity strength"),
        anno::in_group("Wetness parameters"),
        anno::hard_range(0.0, 1.0)
    ]],
    float porosity_scale = 1.0f
    [[
        anno::description("Scale the porosity fetched from the porosity map"),
        anno::display_name("Porosity map scale"),
        anno::in_group("Wetness parameters"),
		anno::soft_range(0.0, 2.0)
    ]],
    uniform texture_2d porosity_map = texture_2d()
    [[
        anno::description("Describes the porosity of object"),
        anno::display_name("Porosity map"),
        anno::in_group("Wetness parameters"),
		anno::usage("porosity")
    ]],
    color water_albedo = color(0.5f)
    [[
        anno::description("Describes the color of the accumulated water"),
        anno::display_name("Water albedo"),
        anno::in_group("Wetness parameters")
    ]],
    float water_transparency = 1.0f
    [[
        anno::description("Describes the transparency of the water"),
        anno::display_name("Water Transparency"),
        anno::in_group("Wetness parameters"),
		anno::hard_range(0.0, 1.0)
    ]],
    float water_accumulation = 0.0f
    [[
        anno::description("Control the water accumulation in case of wetness"),
        anno::display_name("Accumulation"),
        anno::in_group("Wetness parameters"),
        anno::hard_range(0.0, 1.0)
    ]],
    float water_accumulation_scale = 1.0f
    [[
        anno::description("Scale the accumualtion fetched from the accumulation map"),
        anno::display_name("Accumulation map scale"),
        anno::in_group("Wetness parameters"),
		anno::soft_range(0.0, 2.0)
    ]],
    uniform texture_2d water_accumulation_map = texture_2d()
    [[
        anno::description("Describes location on the where water would accumulate"),
        anno::display_name("Accumulation map"),
        anno::in_group("Wetness parameters"),
		anno::usage("water_accumulation")
    ]]
) = let {
	//float3 WorldPositionOffset_mdl = float3(0.0,0.0,0.0);
	float2 uv = float2(state::texture_coordinate(0).x,state::texture_coordinate(0).y);
	float2 CustomizedUV0_mdl = float2(uv.x,1.0-uv.y);

	float3 Local0 = ((state::transform_point(state::coordinate_internal,state::coordinate_world,state::position())*state::meters_per_scene_unit()*100.0) / WorldSpaceUVMult);
	float2 Local1 = (float2(Local0.x,Local0.y) * Set1Tile);
	float4 Local2 = tex::lookup_float4(Set1SuperNormal,float2(Local1.x,1.0-Local1.y),tex::wrap_repeat,tex::wrap_repeat);
	float2 Local3 = (float2(Local0.x,Local0.y) * Set2Tile);
	float4 Local4 = tex::lookup_float4(Set2SuperNormal,float2(Local3.x,1.0-Local3.y),tex::wrap_repeat,tex::wrap_repeat);
	float2 Local5 = (float2(Local0.x,Local0.y) * Set1Set2BlendNoiseTile);
	float4 Local6 = tex::lookup_float4(Set1Set2BlendNoise,float2(Local5.x,1.0-Local5.y),tex::wrap_repeat,tex::wrap_repeat);
	float3 Local7 = math::lerp(float3(Local2.x,Local2.y,Local2.z),float3(Local4.x,Local4.y,Local4.z),Local6.x);
	float3 Local8 = (Local7 * 2.0);
	float3 Local9 = (Local8 - 1.0);
	float3 Local10 = math::lerp(Local7,Local9,NormalConvert);
	float3 Local11 = math::lerp(float3(0.0,0.0,1.0),Local10,NormalAmount);
	float3 Local12 = math::lerp(float3(0.0,0.0,1.0),Local10,Stain0_NormalAmount);
	float2 Local13 = (float2(Local0.x,Local0.y) * Stain0_NoiseTile);
	float4 Local14 = tex::lookup_float4(Stain_Noise,float2(Local13.x,1.0-Local13.y),tex::wrap_repeat,tex::wrap_repeat);
	float Local15 = (1.0 - Local14.x);
	float Local16 = (Local15 * Stain0_ParamA);
	float Local17 = (1.0 + Stain0_ParamB);
	float Local18 = (Stain0_ParamA * -1.0);
	float Local19 = (Local18 + 0.0);
	float Local20 = math::min(Local17,Local19);
	float Local21 = math::max(Local17,Local19);
	float Local22 = (Local17 - Local19);
	float Local23 = (1.0 - Stain0_ParamC);
	float Local24 = (Local22 / Local23);
	float Local25 = math::min(1.0,Stain0_ParamC);
	float Local26 = math::max(1.0,Stain0_ParamC);
	float Local27 = (1.0 - Stain0_Width);
	float Local28 = (1.0 - Local27);
	float Local29 = (Local23 / Local28);
	float4 Local30 = tex::lookup_float4(UV_VertexColor,float2(CustomizedUV0_mdl.x,1.0-CustomizedUV0_mdl.y),tex::wrap_repeat,tex::wrap_repeat);
	float3 Local31 = math::lerp(float3(::vertex_color_from_coordinate(VertexColorCoordinateIndex).x,::vertex_color_from_coordinate(VertexColorCoordinateIndex).y,::vertex_color_from_coordinate(VertexColorCoordinateIndex).z),float3(Local30.x,Local30.y,Local30.z),UV_UseVertexColorFromTexture);
	float3 Local32 = math::pow(Local31,float3(0.5,0.5,0.5));
	float Local33 = (Local32.y - Local27);
	float Local34 = (Local29 * Local33);
	float Local35 = (Local34 + Stain0_ParamC);
	float Local36 = math::min(math::max(Local35,Local25),Local26);
	float Local37 = math::pow(Local36,1.5);
	float Local38 = (Local37 - Stain0_ParamC);
	float Local39 = (Local24 * Local38);
	float Local40 = (Local39 + Local19);
	float Local41 = math::min(math::max(Local40,Local20),Local21);
	float Local42 = (Local16 + Local41);
	float Local43 = math::lerp(1.0,Local14.x,Stain0_NoiseBlend);
	float Local44 = (Local42 * Local43);
	float Local45 = math::min(math::max(Local44,0.0),1.0);
	float Local46 = (Local45 * Stain0_Blend);
	float3 Local47 = math::lerp(Local11,Local12,Local46);
	float3 Local48 = math::lerp(float3(0.0,0.0,1.0),Local10,Stain1_NormalAmount);
	float2 Local49 = (float2(Local0.x,Local0.y) * Stain1_NoiseTile);
	float4 Local50 = tex::lookup_float4(Stain_Noise,float2(Local49.x,1.0-Local49.y),tex::wrap_repeat,tex::wrap_repeat);
	float Local51 = (1.0 - Local50.x);
	float Local52 = (Local51 * Stain1_ParamA);
	float Local53 = (1.0 + Stain1_ParamB);
	float Local54 = (Stain1_ParamA * -1.0);
	float Local55 = (Local54 + 0.0);
	float Local56 = math::min(Local53,Local55);
	float Local57 = math::max(Local53,Local55);
	float Local58 = (Local53 - Local55);
	float Local59 = (1.0 - Stain1_ParamC);
	float Local60 = (Local58 / Local59);
	float Local61 = math::min(1.0,Stain1_ParamC);
	float Local62 = math::max(1.0,Stain1_ParamC);
	float Local63 = (1.0 - Stain1_Width);
	float Local64 = (1.0 - Local63);
	float Local65 = (Local59 / Local64);
	float Local66 = (Local32.x - Local63);
	float Local67 = (Local65 * Local66);
	float Local68 = (Local67 + Stain1_ParamC);
	float Local69 = math::min(math::max(Local68,Local61),Local62);
	float Local70 = math::pow(Local69,1.5);
	float Local71 = (Local70 - Stain1_ParamC);
	float Local72 = (Local60 * Local71);
	float Local73 = (Local72 + Local55);
	float Local74 = math::min(math::max(Local73,Local56),Local57);
	float Local75 = (Local52 + Local74);
	float Local76 = math::lerp(1.0,Local51,Stain1_NoiseBlend);
	float Local77 = (Local75 * Local76);
	float Local78 = math::min(math::max(Local77,0.0),1.0);
	float Local79 = (Local78 * Stain1_Blend);
	float3 Local80 = math::lerp(Local47,Local48,Local79);
	float3 Local81 = math::lerp(float3(0.0,0.0,1.0),Local10,Stain2_NormalAmount);
	float2 Local82 = (float2(Local0.x,Local0.y) * Stain2_NoiseTile);
	float4 Local83 = tex::lookup_float4(Stain_Noise,float2(Local82.x,1.0-Local82.y),tex::wrap_repeat,tex::wrap_repeat);
	float Local84 = (1.0 - Local83.x);
	float Local85 = (Local84 * Stain2_ParamA);
	float Local86 = (1.0 + Stain2_ParamB);
	float Local87 = (Stain2_ParamA * -1.0);
	float Local88 = (Local87 + 0.0);
	float Local89 = math::min(Local86,Local88);
	float Local90 = math::max(Local86,Local88);
	float Local91 = (Local86 - Local88);
	float Local92 = (1.0 - Stain2_ParamC);
	float Local93 = (Local91 / Local92);
	float Local94 = math::min(1.0,Stain2_ParamC);
	float Local95 = math::max(1.0,Stain2_ParamC);
	float Local96 = (1.0 - Stain2_Width);
	float Local97 = (1.0 - Local96);
	float Local98 = (Local92 / Local97);
	float Local99 = (Local32.z - Local96);
	float Local100 = (Local98 * Local99);
	float Local101 = (Local100 + Stain2_ParamC);
	float Local102 = math::min(math::max(Local101,Local94),Local95);
	float Local103 = math::pow(Local102,1.5);
	float Local104 = (Local103 - Stain2_ParamC);
	float Local105 = (Local93 * Local104);
	float Local106 = (Local105 + Local88);
	float Local107 = math::min(math::max(Local106,Local89),Local90);
	float Local108 = (Local85 + Local107);
	float Local109 = math::lerp(1.0,Local84,Stain2_NoiseBlend);
	float Local110 = (Local108 * Local109);
	float Local111 = math::min(math::max(Local110,0.0),1.0);
	float Local112 = (Local111 * Stain2_Blend);
	float3 Local113 = math::lerp(Local80,Local81,Local112);
	float3 Local114 = math::lerp(float3(0.0,0.0,1.0),Local10,Puddle_NormalAmount);
	float2 Local115 = (float2(Local0.x,Local0.y) * Puddle_NoiseTile);
	float4 Local116 = tex::lookup_float4(Puddle_Noise,float2(Local115.x,1.0-Local115.y),tex::wrap_repeat,tex::wrap_repeat);
	float Local117 = (Local116.x * Puddle_NoiseBlend);
	float3 Local118 = math::lerp(Local113,Local114,Local117);

	float3 Normal_mdl = Local118;

	float4 Local119 = tex::lookup_float4(Set1SuperAlbedo,float2(Local1.x,1.0-Local1.y),tex::wrap_repeat,tex::wrap_repeat);
	float4 Local120 = tex::lookup_float4(Set2SuperAlbedo,float2(Local3.x,1.0-Local3.y),tex::wrap_repeat,tex::wrap_repeat);
	float3 Local121 = math::lerp(float3(float2(Local119.x,Local119.y).x,float2(Local119.x,Local119.y).y,Local119.z),float3(float2(Local120.x,Local120.y).x,float2(Local120.x,Local120.y).y,Local120.z),Local6.x);
	float3 Local122 = (Local121 * float3(AlbedoMult.x,AlbedoMult.y,AlbedoMult.z));
	float3 Local123 = math::min(math::max(Local122,float3(0.0,0.0,0.0)),float3(1.0,1.0,1.0));
	float3 Local124 = (Local121 * float3(Stain0_AlbedoMult.x,Stain0_AlbedoMult.y,Stain0_AlbedoMult.z));
	float3 Local125 = math::min(math::max(Local124,float3(0.0,0.0,0.0)),float3(1.0,1.0,1.0));
	float3 Local126 = math::lerp(Local123,Local125,Local46);
	float3 Local127 = (Local121 * float3(Stain1_AlbedoMult.x,Stain1_AlbedoMult.y,Stain1_AlbedoMult.z));
	float3 Local128 = math::min(math::max(Local127,float3(0.0,0.0,0.0)),float3(1.0,1.0,1.0));
	float3 Local129 = math::lerp(Local126,Local128,Local79);
	float3 Local130 = (Local121 * float3(Stain2_AlbedoMult.x,Stain2_AlbedoMult.y,Stain2_AlbedoMult.z));
	float3 Local131 = math::min(math::max(Local130,float3(0.0,0.0,0.0)),float3(1.0,1.0,1.0));
	float3 Local132 = math::lerp(Local129,Local131,Local112);
	float3 Local133 = (Local121 * Puddle_AlbedoMult);
	float3 Local134 = math::min(math::max(Local133,float3(0.0,0.0,0.0)),float3(1.0,1.0,1.0));
	float3 Local135 = math::lerp(Local132,Local134,Local117);
	float Local136 = math::lerp(Local119.w,Local120.w,Local6.x);
	float Local137 = math::pow(Local136,SpecularPow_Order1);
	float Local138 = (Local137 * SpecularMult_Order2);
	float Local139 = math::pow(Local136,Stain0_SpecularPow_Order1);
	float Local140 = (Local139 * Stain0_SpecularMult_Order2);
	float Local141 = math::lerp(Local138,Local140,Local46);
	float Local142 = math::pow(Local136,Stain1_SpecularPow_Order1);
	float Local143 = (Local142 * Stain1_SpecularMult_Order2);
	float Local144 = math::lerp(Local141,Local143,Local79);
	float Local145 = math::pow(Local136,Stain2_SpecularPow_Order1);
	float Local146 = (Local145 * Stain2_SpecularMult_Order2);
	float Local147 = math::lerp(Local144,Local146,Local112);
	float Local148 = math::pow(Local136,Puddle_SpecularPow_Order1);
	float Local149 = (Local148 * Puddle_SpecularMult_Order2);
	float Local150 = math::lerp(Local147,Local149,Local117);
	float Local151 = math::lerp(Local2.w,Local4.w,Local6.x);
	float Local152 = math::pow(Local151,RoughnessPow_Order1);
	float Local153 = (Local152 * RoughnessMult_Order2);
	float Local154 = (Local153 + RoughnessOffset_Order3);
	float Local155 = math::pow(Local151,Stain0_RoughnessPow_Order1);
	float Local156 = (Local155 * Stain0_RoughnessMult_Order2);
	float Local157 = (Local156 + Stain0_RoughnessOffset_Order3);
	float Local158 = math::lerp(Local154,Local157,Local46);
	float Local159 = math::pow(Local151,Stain1_RoughnessPow_Order1);
	float Local160 = (Local159 * Stain1_RoughnessMult_Order2);
	float Local161 = (Local160 + Stain1_RoughnessOffset_Order3);
	float Local162 = math::lerp(Local158,Local161,Local79);
	float Local163 = math::pow(Local151,Stain2_RoughnessPow_Order1);
	float Local164 = (Local163 * Stain2_RoughnessMult_Order2);
	float Local165 = (Local164 + Stain2_RoughnessOffset_Order3);
	float Local166 = math::lerp(Local162,Local165,Local112);
	float Local167 = math::pow(Local151,Puddle_RoughnessPow_Order1);
	float Local168 = (Local167 * Puddle_RoughnessMult_Order2);
	float Local169 = (Local168 + 0);
	float Local170 = math::lerp(Local166,Local169,Local117);

	float3 BaseColor_mdl = Local135;
	float Metallic_mdl = 0.0;
	float Specular_mdl = Local150;
	float Roughness_mdl = Local170;

	material base = ::SimPBR_Model::SimPBR_Model(
			diffuse_color: color(BaseColor_mdl),
			roughness: Roughness_mdl,
    		metallic: Metallic_mdl,
    		specular: Specular_mdl,
    		normal: Normal_mdl);

    // Wetness
	float3 uv3 = state::transform_point(state::coordinate_internal, state::coordinate_world, state::position()) * state::meters_per_scene_unit();
	float2 uv2 = (float2(uv3.x, uv3.y) - TileOrigin) / TileSize;

    float local_accumulation = water_accumulation_scale * (tex::texture_isvalid(water_accumulation_map) ? tex::lookup_float4(tex: water_accumulation_map, coord: uv2).x : water_accumulation);
    float local_porosity = porosity_scale * (tex::texture_isvalid(porosity_map) ? tex::lookup_float4(tex: porosity_map, coord: uv2).x : porosity);

	material wetsimpbr = SimPBR_Core::apply_wetness(
        	base: base,

        	base_color: color(BaseColor_mdl),
        	wetness: wetness,
        	water_albedo: water_albedo,
        	water_transparency: water_transparency,
        	porosity: local_porosity,
        	water_accumulation: local_accumulation
    	);

	material final = enable_wetness ? wetsimpbr : base;

} in final;